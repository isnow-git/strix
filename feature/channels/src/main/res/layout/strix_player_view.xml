<?xml version="1.0" encoding="utf-8"?>
<!--
  A controller-less PlayerView backed by a TextureView. TextureView (not the default
  SurfaceView) is used so the surface transforms cleanly under a Compose graphicsLayer
  during the preview->fullscreen scale/translate morph; a SurfaceView can glitch or
  punch through during that animation on API 30.
-->
<androidx.media3.ui.PlayerView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:use_controller="false"
    app:surface_type="texture_view"
    app:resize_mode="fit" />
